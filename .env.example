# Synaplan Qdrant Configuration
# Copy to .env and customize for your environment.
#
# Local Development:
#   cp .env.example .env
#   docker compose up -d
#
# Cluster Deployment:
#   See CLUSTER.md

# =============================================================================
# Qdrant Configuration
# =============================================================================

# Optional: Enable Qdrant native API key authentication
# Clients must send this key as `api-key` header.
# QDRANT_API_KEY=

# Collection settings (Synaplan creates collections automatically)
# These are only used by setup-collection.sh for manual creation.
QDRANT_COLLECTION_NAME=user_memories
QDRANT_VECTOR_DIMENSION=1024

# =============================================================================
# Logging
# =============================================================================
QDRANT_LOG_LEVEL=INFO
